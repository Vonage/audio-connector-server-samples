# OpenAI model access for Pipecat STT/LLM/TTS
OPENAI_API_KEY=

# Enter either your Vonage Video Application or OpenTok Project Credentials

# Option A — Vonage Video Application credentials
# The private key can be the key as a string or a path to a file
VONAGE_APPLICATION_ID=YOUR_APPLICATION_ID
VONAGE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
-----END PRIVATE KEY-----"
#VONAGE_PRIVATE_KEY=/path/to/private.key

# Option B — OpenTok project credentials
OPENTOK_API_KEY=YOUR_API_KEY
OPENTOK_API_SECRET=YOUR_API_SECRET

# A routed Vonage Video session (from Playground or Video API)
VONAGE_SESSION_ID=YOUR_SESSION_ID

# Doctor defaults for scheduling and notifications
TRIAGE_DOCTOR_NAME=Dr. Demo
TRIAGE_DOCTOR_PHONE=+10000000001
TRIAGE_DOCTOR_SPECIALITY=General Medicine
TRANSCRIPT_DIR=transcripts

# Websocket URL of your Pipecat server (ngrok or production)
WS_URI=wss://<your-ngrok-domain>/ws

# Optional doctor URL used in doctor notification payload
DOCTOR_JOIN_URL=

# Optional API URL override
API_URL=https://api.opentok.com

# Audio rate for Vonage websocket bridge (8k or 16k recommended)
VONAGE_AUDIO_RATE=16000

# N8N webhooks
N8N_TRANSCRIPT_WEBHOOK=http://localhost:5678/webhook/triage/transcript
N8N_AVAILABILITY_WEBHOOK=http://localhost:5678/webhook/triage/availability
N8N_SCHEDULE_WEBHOOK=http://localhost:5678/webhook/triage/schedule
N8N_SMS_WEBHOOK=http://localhost:5678/webhook/triage/sms
N8N_DOCTOR_NOTIFY_WEBHOOK=http://localhost:5678/webhook/triage/doctor-notify

# Optional server port
PORT=8005
